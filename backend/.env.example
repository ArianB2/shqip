# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ─────────────────────────────────────────────────────────────────
# Month 1: leave as-is (no database used yet)
# Month 2: replace with your Amazon RDS endpoint
DATABASE_URL=postgresql://shqip_user:your_password@localhost:5432/shqip

# ── AWS ──────────────────────────────────────────────────────────────────────
# Create an IAM user in the AWS console and paste credentials here.
# Month 1: not required yet
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ── Amazon Cognito (Month 2) ──────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_client_id_here

# ── Amazon Bedrock (Month 3) ──────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
